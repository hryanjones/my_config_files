[global_config]
  focus = mouse
[keybindings]
[profiles]
  [[default]]
    audible_bell = True
    visible_bell = True
    urgent_bell = True
    background_color = "#002b36"
    font = Ubuntu Mono 12
    foreground_color = "#839496"
    scrollback_lines = 10000000
    use_system_font = False
[layouts]
  [[default]]
    [[[child1]]]
      parent = window0
      type = Terminal
    [[[window0]]]
      parent = ""
      type = Window
[plugins]
